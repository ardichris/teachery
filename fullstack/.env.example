# Optional. Kosongkan untuk memakai API route Next.js sendiri (/api).
# NEXT_PUBLIC_API_URL=/api

# Turso/libSQL database untuk API route Next.js di Vercel.
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# Auth JWT untuk session Teachery.
JWT_SECRET=change-this-secret

# AI Provider Sumopod.
SUMOPOD_API_KEY=sk-your-sumopod-key
SUMOPOD_API_URL=https://ai.sumopod.com/v1/chat/completions
SUMOPOD_QUESTION_MODEL=gpt-4o-mini
SUMOPOD_EXPLANATION_MODEL=gpt-4o-mini
